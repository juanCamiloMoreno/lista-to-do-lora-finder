' ────────────────────────────────────────────────────────────
' DIAGRAMA 1: Arquitectura de componentes
' ────────────────────────────────────────────────────────────
@startuml Arquitectura_Componentes
!theme plain
skinparam componentStyle rectangle
skinparam backgroundColor #FEFEFE
skinparam component {
    BackgroundColor #EAF4FB
    BorderColor #2980B9
}
skinparam package {
    BackgroundColor #F9F9F9
    BorderColor #AAA
}

title LoRa Finder — Arquitectura de Módulos

package "Punto de entrada" {
    component [main.cpp\nsetup() / loop()] as MAIN
    component [app.cpp\napp_init() / app_run()] as APP
}

package "Gestión de roles" {
    component [role_manager\nROLE_NONE · SEARCHER · TARGET · TEST] as RM
    component [power.cpp\nStandby display] as PWR
}

package "Máquinas de estado" {
    component [fsm_searcher\n7 estados] as SRCH #D5F5E3
    component [fsm_target\n5 estados] as TGT #FDEBD0
    component [test_menu\nPruebas campo] as TEST
}

package "Protocolo" {
    component [lora_comm\nCapa protocolo TX/RX] as COMM
    component [lora_msg.h\npaquete 17 bytes] as MSG
    component [navigation\nHaversine + Bearing] as NAV
}

package "Drivers" {
    component [lora driver\nRadioLib / SX1262] as DLORA
    component [gps driver\nTinyGPS++ / NEO-M8N] as DGPS
    component [compass driver\nQMC5883L / I2C1] as DCMP
    component [display driver\nSSD1306 / I2C0] as DDSP
    component [battery driver\nADC GPIO1] as DBAT
    component [btn driver\nDebounce + Hold] as DBTN
    component [alert driver\nBuzzer + Vibrador + LED] as DALT
}

package "Hardware" #E8F8F5 {
    component [SX1262\n915 MHz · SPI] as HW_LORA #D4E6F1
    component [NEO-M8N\nUART2] as HW_GPS #D5F5E3
    component [QMC5883L\nWire1] as HW_CMP #FDEBD0
    component [OLED 128×64\nWire0] as HW_OLED #E8DAEF
    component [GPIO 2·3·4\nBTN UP/DN/SEL] as HW_BTN
}

MAIN --> APP
APP  --> RM

RM --> SRCH
RM --> TGT
RM --> TEST
RM --> PWR

SRCH --> COMM
SRCH --> NAV
SRCH --> DGPS
SRCH --> DCMP
SRCH --> DDSP
SRCH --> DBAT
SRCH --> DBTN
SRCH --> DALT

TGT --> COMM
TGT --> DGPS
TGT --> DCMP
TGT --> DDSP
TGT --> DBAT
TGT --> DBTN
TGT --> DALT

COMM --> MSG
COMM --> DLORA
COMM --> DALT

DLORA --> HW_LORA
DGPS  --> HW_GPS
DCMP  --> HW_CMP
DDSP  --> HW_OLED
DBTN  --> HW_BTN

@enduml


' ────────────────────────────────────────────────────────────
' DIAGRAMA 2: Role Manager — Máquina de estados
' ────────────────────────────────────────────────────────────
@startuml Role_Manager
!theme plain
skinparam backgroundColor #FEFEFE
skinparam state {
    BackgroundColor #EAF4FB
    BorderColor #2980B9
    ArrowColor #2C3E50
    FontSize 12
}

title Role Manager — Asignación dinámica de roles

[*] --> ROLE_NONE : Encendido

state ROLE_NONE : Pantalla de inicio\nBrújula + batería\nEscucha pasiva LoRa\nStandby display si inactivo

state ROLE_SEARCHER : FSM Buscador activo\n(fsm_searcher.cpp)

state ROLE_TARGET : FSM Objetivo activo\n(fsm_target.cpp)

state ROLE_TEST_MENU : Menú pruebas campo\n(test_menu.cpp)

ROLE_NONE --> ROLE_SEARCHER  : BTN_SELECT\n[cursor = BUSCAR]
ROLE_NONE --> ROLE_TARGET    : Recibe MSG_SEARCH_START\npor LoRa (cualquier momento)
ROLE_NONE --> ROLE_TEST_MENU : BTN_SELECT\n[cursor = MENU]

ROLE_SEARCHER  --> ROLE_NONE : fsm_searcher_is_done()
ROLE_TARGET    --> ROLE_NONE : fsm_target_is_done()
ROLE_TEST_MENU --> ROLE_NONE : test_menu_is_done()

note right of ROLE_NONE
  Ambos dispositivos son
  hardware y firmware idénticos.
  El rol se determina por quién
  presiona el botón primero
  o quién recibe el mensaje.
end note

@enduml


' ────────────────────────────────────────────────────────────
' DIAGRAMA 3: FSM Buscador (fsm_searcher)
' ────────────────────────────────────────────────────────────
@startuml FSM_Buscador
!theme plain
skinparam backgroundColor #FEFEFE
skinparam state {
    BackgroundColor #D5F5E3
    BorderColor #27AE60
    ArrowColor #1A5276
    FontSize 11
}

title FSM Buscador (fsm_searcher.cpp) — 7 estados

[*] --> SEARCHER_SEARCHING : fsm_searcher_init()\nEnvía MSG_SEARCH_START

state SEARCHER_SEARCHING : Pantalla: "Buscando..."\nBarra de progreso\nReintenta cada 3 s\nMáx 5 intentos (15 s total)

state SEARCHER_NAV_GPS : Pantalla: flecha + distancia\nEnvía MSG_STATUS cada 2 s\nRecibe MSG_BEACON cada 2 s\nCalcula Haversine + bearing

state SEARCHER_NAV_RSSI : Pantalla: RSSI + CALIENTE/FRÍO\nSin coordenadas GPS\nNavegación por señal

state SEARCHER_SIGNAL_LOST : Pantalla: "Señal perdida"\nMuestra tiempo sin señal\nÚltimo RSSI conocido\nSigue enviando STATUS

state SEARCHER_REUNITED : Pantalla: "¡REUNIDOS!"\nEnvía MSG_REUNITE_CONFIRM\nDuración 4 s

state SEARCHER_SOS : Pantalla: "! SOS !"\nAlerta periódica cada 5 s\nSigue enviando STATUS

state SEARCHER_DONE : Fin de sesión\n→ vuelve a ROLE_NONE

SEARCHER_SEARCHING --> SEARCHER_NAV_GPS  : Recibe MSG_ACK\n[lat_i ≠ 0 → GPS válido]
SEARCHER_SEARCHING --> SEARCHER_NAV_RSSI : Recibe MSG_ACK\n[lat_i = 0 → sin GPS]
SEARCHER_SEARCHING --> SEARCHER_DONE     : 5 reintentos sin ACK\no BTN_SELECT

SEARCHER_NAV_GPS  --> SEARCHER_NAV_RSSI  : BEACON con lat_i = 0\n(objetivo perdió GPS)
SEARCHER_NAV_RSSI --> SEARCHER_NAV_GPS   : BEACON con lat_i ≠ 0\n(objetivo recuperó GPS)

SEARCHER_NAV_GPS  --> SEARCHER_REUNITED  : distancia < 20 m\no RSSI > −60 dBm
SEARCHER_NAV_RSSI --> SEARCHER_REUNITED  : RSSI > −60 dBm

SEARCHER_NAV_GPS  --> SEARCHER_SIGNAL_LOST : Sin paquetes durante 15 s
SEARCHER_NAV_RSSI --> SEARCHER_SIGNAL_LOST : Sin paquetes durante 15 s

SEARCHER_NAV_GPS  --> SEARCHER_SOS       : Recibe MSG_SOS_ALERT
SEARCHER_NAV_RSSI --> SEARCHER_SOS       : Recibe MSG_SOS_ALERT

SEARCHER_NAV_GPS  --> SEARCHER_DONE      : BTN_SELECT
SEARCHER_NAV_RSSI --> SEARCHER_DONE      : BTN_SELECT

SEARCHER_SIGNAL_LOST --> SEARCHER_NAV_GPS  : Recibe BEACON\n[con GPS]
SEARCHER_SIGNAL_LOST --> SEARCHER_NAV_RSSI : Recibe BEACON\n[sin GPS]
SEARCHER_SIGNAL_LOST --> SEARCHER_DONE     : 60 s sin señal\no BTN_SELECT

SEARCHER_REUNITED --> SEARCHER_DONE : BTN_SELECT\no timeout 4 s

SEARCHER_SOS --> SEARCHER_NAV_GPS  : BTN_SELECT (entendido)\no recibe MSG_SOS_CANCEL [con GPS]
SEARCHER_SOS --> SEARCHER_NAV_RSSI : recibe MSG_SOS_CANCEL [sin GPS]

SEARCHER_DONE --> [*]

@enduml


' ────────────────────────────────────────────────────────────
' DIAGRAMA 4: FSM Objetivo (fsm_target)
' ────────────────────────────────────────────────────────────
@startuml FSM_Objetivo
!theme plain
skinparam backgroundColor #FEFEFE
skinparam state {
    BackgroundColor #FDEBD0
    BorderColor #E67E22
    ArrowColor #784212
    FontSize 11
}

title FSM Objetivo (fsm_target.cpp) — 5 estados

[*] --> TARGET_ALERTING : fsm_target_init()\nRecibe MSG_SEARCH_START

state TARGET_ALERTING : Pantalla: "¡Te buscan!"\nBuzzer + vibrador cada 3 s\nEspera BTN_SELECT del usuario\nTimeout: 60 s

state TARGET_BEACON : Pantalla: Modo baliza\nMuestra GPS propio\nEnvía MSG_BEACON cada 2 s\n(lat, lon, heading, bat, RSSI)

state TARGET_SOS : Pantalla: "SOS ACTIVO"\nEnvía MSG_SOS_ALERT cada 1 s\nBuzzer + vibrador continuos

state TARGET_REUNITED : Pantalla: "¡REUNIDOS!"\nMisión completada\nDuración 4 s

state TARGET_DONE : Fin de sesión\n→ vuelve a ROLE_NONE

TARGET_ALERTING --> TARGET_BEACON  : BTN_SELECT presionado\n→ envía MSG_ACK con GPS
TARGET_ALERTING --> TARGET_DONE    : Timeout 60 s\n(usuario no respondió)

TARGET_BEACON --> TARGET_SOS      : BTN_UP sostenido 2 s\n→ envía MSG_SOS_ALERT
TARGET_BEACON --> TARGET_REUNITED : Recibe MSG_REUNITE_CONFIRM\ndel buscador
TARGET_BEACON --> TARGET_DONE     : BTN_SELECT\n→ envía MSG_REUNITE_CONFIRM

TARGET_SOS --> TARGET_BEACON  : BTN_SELECT (cancelar)\n→ envía MSG_SOS_CANCEL

TARGET_REUNITED --> TARGET_DONE : Timeout 4 s

TARGET_DONE --> [*]

note right of TARGET_BEACON
  BTN_UP sostenido 2 s
  activa modo SOS de emergencia
end note

@enduml


' ────────────────────────────────────────────────────────────
' DIAGRAMA 5: Diagrama de secuencia — sesión completa
' ────────────────────────────────────────────────────────────
@startuml Secuencia_Sesion
!theme plain
skinparam backgroundColor #FEFEFE
skinparam sequence {
    ArrowColor #2C3E50
    ActorBorderColor #2980B9
    ParticipantBackgroundColor #EAF4FB
    ParticipantBorderColor #2980B9
    BoxBackgroundColor #F4F6F7
}

title Flujo de mensajes — Sesión de búsqueda completa

participant "Dispositivo A\n(Buscador)" as A
participant "Dispositivo B\n(Objetivo)" as B

== Inicio de búsqueda ==
note over A : BTN_SELECT → ROLE_SEARCHER\nEstado: SEARCHER_SEARCHING

A ->> B : MSG_SEARCH_START\n[sender_id, lat, lon, heading, bat]
note over B : No responde (no ha escuchado)

A ->> B : MSG_SEARCH_START (reintento 2/5)
note over B : Recibe → ROLE_TARGET\nEstado: TARGET_ALERTING\nBuzzer + vibrador

note over B : BTN_SELECT → acepta

B ->> A : MSG_ACK\n[sender_id, lat_i, lon_i, bat_pct]
note over A : Recibe ACK con GPS → SEARCHER_NAV_GPS\nRecibe ACK sin GPS → SEARCHER_NAV_RSSI

== Navegación (cada 2 segundos) ==

loop Modo búsqueda activo
    A ->> B : MSG_STATUS\n[posición del buscador]
    B ->> A : MSG_BEACON\n[posición del objetivo]
    note over A : Calcula distancia y bearing\nActualiza pantalla: flecha + metros
end

== Caso SOS (opcional) ==

B ->> A : MSG_SOS_ALERT
note over A : Estado → SEARCHER_SOS\nAlertas periódicas cada 5 s
note over B : Estado → TARGET_SOS\nEnvía MSG_SOS_ALERT cada 1 s

note over A : BTN_SELECT → "entendido"

B ->> A : MSG_SOS_CANCEL
note over A : Vuelve a SEARCHER_NAV_GPS

== Reunión ==

note over A : Distancia < 20 m\no RSSI > −60 dBm

A ->> B : MSG_REUNITE_CONFIRM
note over A : Estado → SEARCHER_REUNITED
note over B : Estado → TARGET_REUNITED

note over A, B : Ambos muestran "¡REUNIDOS!"\nAmbos vuelven a ROLE_NONE

@enduml


' ────────────────────────────────────────────────────────────
' DIAGRAMA 6: Estructura del paquete lora_msg_t
' ────────────────────────────────────────────────────────────
@startuml Estructura_Paquete
!theme plain
skinparam backgroundColor #FEFEFE

title Estructura del paquete lora_msg_t — 17 bytes

class lora_msg_t << (S,#AABBCC) struct packed >> {
    + msg_type     : uint8_t    ' byte 0 — tipo de mensaje
    + sender_id    : uint32_t   ' bytes 1–4 — últimos 4B del MAC
    + lat_i        : int32_t    ' bytes 5–8 — latitud × 10⁶
    + lon_i        : int32_t    ' bytes 9–12 — longitud × 10⁶
    + heading_x10  : int16_t    ' bytes 13–14 — rumbo × 10 (0–3599)
    + bat_pct      : uint8_t    ' byte 15 — batería 0–100 %
    + rssi_last    : int8_t     ' byte 16 — RSSI recibido en dBm
}

note right of lora_msg_t
  static_assert(sizeof == 17)

  Tipos de mensaje:
  0x01 MSG_SEARCH_START
  0x02 MSG_ACK
  0x03 MSG_STATUS
  0x04 MSG_BEACON
  0x05 MSG_SOS_ALERT
  0x06 MSG_SOS_CANCEL
  0x07 MSG_REUNITE_CONFIRM
  0x10 MSG_TEST_PING
  0x11 MSG_TEST_PONG
end note

@enduml
